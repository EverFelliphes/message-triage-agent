# ─────────────────────────────────────────────────────────────────────────────
# Classifier — which LLM backs the triage call. The provider abstraction
# (src/triage/providers.py) lets you swap models by config alone.
# ─────────────────────────────────────────────────────────────────────────────
CLASSIFIER_PROVIDER=anthropic          # anthropic | gemini

# Only the key for the selected CLASSIFIER_PROVIDER is required.
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Classifier model id — must match CLASSIFIER_PROVIDER's family.
#   anthropic: claude-opus-4-8  (most capable) | claude-sonnet-5 (best value) | claude-haiku-4-5 (cheapest)
#   gemini:    gemini-2.5-pro   (most capable) | gemini-2.5-flash | gemini-2.0-flash (cheapest)
CLASSIFIER_MODEL=claude-sonnet-5

# ─────────────────────────────────────────────────────────────────────────────
# Judge — cross-family LLM-as-a-Judge, used offline by the evaluation pipeline.
# Reuses the same provider adapters as the classifier. For the bias mitigation to
# hold, keep the judge in a DIFFERENT family than the classifier.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# Leave JUDGE_PROVIDER empty to auto-pick a cross-family provider whose key is
# present (openai → gemini), falling back to the classifier's family with a
# warning. Pin it together with a matching JUDGE_MODEL to force a specific judge.
JUDGE_PROVIDER=gemini                       # (empty = auto) | openai | gemini | anthropic

# Judge model id — must match JUDGE_PROVIDER's family (ignored in auto mode,
# which picks a sensible default per provider).
#   openai:    gpt-4o (recommended) | gpt-4.1 | gpt-4-turbo
#   gemini:    gemini-2.5-pro | gemini-2.5-flash
#   anthropic: claude-opus-4-8 (same-family fallback only)
JUDGE_MODEL=gemini-2.5-flash

LOG_LEVEL=INFO

# Timezone for the structured-log timestamps (used by docker-compose). Logs are
# persisted as JSONL under storage/logs/ with tz-aware ISO-8601 timestamps.
TZ=America/Sao_Paulo
